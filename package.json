    "@types/firefox": "^0.0.34",
    "@types/web": "^0.0.285",
    "@types/webextension-polyfill": "^0.12.5",
    "esbuild": "^0.27.3",
    "html-minifier-next": "^4.19.1",
    "mathjax": "^4.1.0",
    "mathml-to-latex": "^1.5.0",
    "node-html-parser": "^7.0.2",
    "typescript": "^5.9.3",
    "web-ext": "9.1.0",
    "webextension-polyfill": "^0.12.0"
  }

{
  "name": "notexp-addon",
  "version": "2.2.0",
  "description": "One-click browser addon to export online notes to Xournal++ and RNote compatible formats",
  "type": "module",
  "scripts": {
    "build": "node ./build.js && web-ext lint --source-dir dist",
    "pack": "web-ext lint --source-dir dist && web-ext build --source-dir dist --overwrite-dest",
    "start:firefox": "web-ext run --source-dir dist "
  },
  "keywords": [],
  "author": "",
  "license": "GPL-3.0",
  "devDependencies": {
    "@mathjax/src": "^4.1.1",
    "@types/chrome": "^0.1.39",
    "@types/firefox": "^0.0.34",
    "@types/web": "^0.0.345",
    "@types/webextension-polyfill": "^0.12.5",
    "esbuild": "^0.28.0",
    "html-minifier-next": "^6.0.0",
    "mathjax": "^4.1.1",
    "mathml-to-latex": "^1.5.0",
    "node-html-parser": "^7.1.0",
    "typescript": "^6.0.2",
    "web-ext": "^10.1.0",
    "webextension-polyfill": "^0.12.0"
  }
}

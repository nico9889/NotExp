{
  "manifest_version": 3,
  "name": "NotExp",
  "description": "This addon converts OneNote notes to Xournal++ or RNote notes.",
  "default_locale": "en",
  "version": "2.2.1",
  "author": "nico9889",
  "homepage_url": "https://codeberg.org/nico9889/NotExp",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
  ],
  "content_scripts": [
    {
      "matches": [
        "https://onenote.officeapps.live.com/*",
        "https://*.officeapps.live.com/*"
      ],
      "all_frames": true,
      "js": [
        "content.js"
      ]
    }
  ],
  "icons": {
    "256": "NotExp.png"
  },
  "sidebar_action": {
    "default_icon": {
      "256": "NotExp.png"
    },
    "default_title": "NotExp - Export your notes",
    "default_panel": "popup.html"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "256": "NotExp.png"
    },
    "default_title": "NotExp - Export your notes"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{2986a98d-8431-4ed3-af49-df7b89bc555e}",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    },
    "gecko_android": {
      "strict_min_version": "142.0"
    }
  }
}
